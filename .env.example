PORT=4173

# Admin dashboard protection
HARITO_ADMIN_TOKEN=change-this-before-production

# Local order storage is used by default.
# For production, connect a managed database and move order storage off JSON files.
DATABASE_URL=

# Legacy direct-payment setup.
# Do not fill these unless Nikith explicitly restarts direct Harito commerce.
# The active storefront direction is affiliate links, where sellers handle checkout.
HARITO_ENABLE_LIVE_PAYMENTS=false
HARITO_UPI_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
HARITO_WEBHOOK_SECRET=change-this-before-production
